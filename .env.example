# ==============================================================================
# MS SQL Server Configuration
# ==============================================================================

# Database server host (e.g., localhost, 127.0.0.1, or remote IP)
DB_SERVER=localhost

# Database name
DB_DATABASE=your_database_name

# Use Windows Authentication (True/False)
# If True, DB_USERNAME and DB_PASSWORD are ignored
DB_USE_WINDOWS_AUTH=True

# Database credentials (required only if DB_USE_WINDOWS_AUTH=False)
DB_USERNAME=
DB_PASSWORD=

# Database connection library to use ('pyodbc' or 'pymssql')
# pyodbc is recommended on Windows if ODBC Driver 17/18 is installed.
# pymssql is pure Python and does not require system-level ODBC drivers.
DB_LIBRARY=pymssql

# For pyodbc only: The exact ODBC Driver name installed on your system.
# Common values:
# - {ODBC Driver 17 for SQL Server}
# - {ODBC Driver 18 for SQL Server}
# - {SQL Server}
DB_ODBC_DRIVER={ODBC Driver 17 for SQL Server}
